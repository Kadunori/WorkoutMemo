# このファイルをコピーして .env を作成
# cp .env.example .env

# JWT シークレット（本番では openssl rand -hex 32 で生成）
JWT_SECRET=dev-jwt-secret-change-in-production

# DB 接続（docker-compose 用）
AUTH_DATABASE_URL=postgres://workout:devpassword@postgres:5432/auth_db?sslmode=disable
WORKOUT_DATABASE_URL=postgres://workout:devpassword@postgres:5432/workout_db?sslmode=disable
USER_DATABASE_URL=postgres://workout:devpassword@postgres:5432/user_db?sslmode=disable
MENU_DATABASE_URL=postgres://workout:devpassword@postgres:5432/menu_db?sslmode=disable

# サービス間通信 URL（docker-compose）
WORKOUT_SERVICE_URL=http://workout-service:8080
USER_SERVICE_URL=http://user-service:8080

# AWS（EKS デプロイ時）
AWS_REGION=ap-northeast-1
ECR_REPO=<aws_account_id>.dkr.ecr.ap-northeast-1.amazonaws.com/workoutmemo
EKS_CLUSTER_NAME=workout-memo-cluster
